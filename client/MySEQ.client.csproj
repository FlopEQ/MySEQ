    <None Include="Resources\toolbar.bmp" />
    <None Include="Resources\Zoom_Out.PNG" />
    <None Include="Resources\Zoom_In.PNG" />
    <None Include="Resources\options.bmp" />
    <None Include="Resources\Increase.bmp" />
